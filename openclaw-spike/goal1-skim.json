    {
      "type": "function",
      "function": {
        "name": "sessions_list",
        "description": "List visible sessions with optional filters for kind, recent activity, and last messages. Use this to discover a target session before calling sessions_history or sessions_send.",
        "parameters": {
          "type": "object",
          "properties": {
            "kinds": {
              "type": "array",
              "items": {
                "type": "string"
              }
