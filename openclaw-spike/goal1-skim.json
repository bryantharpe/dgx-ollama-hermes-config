                      "description": "ISO-8601 timestamp (kind=at)",
                      "type": "string"
                    },
                    "everyMs": {
                      "description": "Interval in milliseconds (kind=every)",
                      "type": "number"
                    },
                    "anchorMs": {
                      "description": "Optional start anchor in milliseconds (kind=every)",
                      "type": "number"
