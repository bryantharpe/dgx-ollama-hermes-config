# Copy to .env and fill in real values.
# Generate auth tokens with: openssl rand -hex 32

# Home Assistant integration
HOME_ASSISTANT_URL=http://ha.internal:8123
HOME_ASSISTANT_TOKEN=replace-with-ha-long-lived-token

# Search / network tool API keys
BRAVE_API_KEY=replace-with-brave-api-key
UNIFI_API_KEY=replace-with-unifi-api-key

# Vault (dev mode root token for local use)
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

# Service auth — shared between hermes-agent and open-webui (open-webui is a client of hermes-agent)
HERMES_API_KEY=replace-with-openssl-rand-hex-32

# OpenCode HTTP basic-auth password (username is `opencode`)
OPENCODE_PASSWORD=replace-with-openssl-rand-hex-32

# Paths — must match the bind-mount targets in docker-compose.yml
HERMES_PROTOTYPES_DIR=/home/admin/code/hermes-config/prototypes
