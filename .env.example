# Copy to .env and fill in real values.
# Generate auth tokens with: openssl rand -hex 32

# Home Assistant integration
HOME_ASSISTANT_URL=http://ha.internal:8123
HOME_ASSISTANT_TOKEN=replace-with-ha-long-lived-token

# Search / network tool API keys
BRAVE_API_KEY=replace-with-brave-api-key
UNIFI_API_KEY=replace-with-unifi-api-key

# Vault (dev mode root token for local use)
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

# Service auth — shared between hermes-agent and open-webui (open-webui is a client of hermes-agent)
HERMES_API_KEY=replace-with-openssl-rand-hex-32

# OpenCode HTTP basic-auth password (username is `opencode`)
OPENCODE_PASSWORD=replace-with-openssl-rand-hex-32

# Paths — must match the bind-mount targets in docker-compose.yml
HERMES_PROTOTYPES_DIR=/home/admin/code/hermes-config/prototypes

# Optional: HuggingFace token. Only needed for gated models — Qwen3.6-35B-A3B-FP8
# is currently public, so this can be left empty.
HF_TOKEN=

# Hindsight memory backend (Fly.io + Neon pgvector) — see hindsight/fly.toml
# Neon: use the DIRECT connection URL, not the -pooler variant
NEON_HINDSIGHT_DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
CEREBRAS_API_KEY=replace-with-csk-key
HINDSIGHT_API_URL=https://hindsight-bryan.fly.dev
HINDSIGHT_API_TENANT_API_KEY=replace-with-openssl-rand-hex-32
HINDSIGHT_BANK_ID=bryan-default

# gbrain (personal knowledge brain) — see gbrain/README.md
# Profile-gated until baseline stable: `docker compose --profile gbrain up -d gbrain`
# Brain data lives at /home/admin/.gbrain/ (host) and is its own private git
# repo at git@github.com:bryantharpe/gbrain-data.git. CEREBRAS_API_KEY above
# is reused for the heavy-synthesis tier (book-mirror, dream).
GBRAIN_BRAIN_DIR=/home/admin/.gbrain
GBRAIN_BRAIN_REMOTE=git@github.com:bryantharpe/gbrain-data.git
GBRAIN_DEPLOY_KEY_PATH=/home/admin/.ssh/gbrain_data_deploy_ed25519
# gbrain Postgres password — local-only, never published. `openssl rand -hex 32`.
GBRAIN_POSTGRES_PASSWORD=replace-with-openssl-rand-hex-32
# Provider routing (overrides gbrain defaults at container startup).
GBRAIN_EMBEDDING_BASE_URL=http://ollama:11434/v1
GBRAIN_EMBEDDING_MODEL=nomic-embed-text
GBRAIN_EMBEDDING_DIMENSIONS=768
GBRAIN_LLM_BASE_URL=http://vllm:8000/v1
GBRAIN_LLM_MODEL=qwen3.6-27b-int4:128k
GBRAIN_HEAVY_LLM_BASE_URL=https://api.cerebras.ai/v1
GBRAIN_HEAVY_LLM_MODEL=qwen-3-235b-a22b-instruct-2507
