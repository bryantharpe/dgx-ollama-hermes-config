OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_CONFIG_DIR=/home/admin/.openclaw
OPENCLAW_WORKSPACE_DIR=/home/admin/.openclaw/workspace
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_TZ=UTC
OPENCLAW_GATEWAY_TOKEN=

# Brave Search API key for the built-in web_search tool.
# Get one at https://brave.com/search/api/ (Search plan; $5/mo credit covers ~1k queries).
# Set a usage cap in the Brave dashboard. Leave empty to disable web_search.
BRAVE_API_KEY=

# Build-phase integration (meeting-specs-to-prototype skill)
# OPENCODE_PASSWORD must match the value in ../.env (hermes-config/.env)
OPENCODE_URL=http://opencode:4096
OPENCODE_USERNAME=opencode
OPENCODE_PASSWORD=
SEEDER_URL=http://prototype-seeder:8080
PROTOTYPES_DIR=/home/node/prototypes
