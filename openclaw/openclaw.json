{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "trustedProxies": [
      "172.23.0.0/16"
    ],
    "controlUi": {
      "allowedOrigins": [
        "http://127.0.0.1:18789",
        "http://localhost:18789",
        "http://192.168.10.80:18789",
        "https://192.168.10.80",
        "https://localhost",
        "https://127.0.0.1"
      ]
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}",
      "rateLimit": {
        "maxAttempts": 10,
        "windowMs": 60000,
        "lockoutMs": 300000
      }
    }
  },
  "models": {
    "providers": {
      "vllm": {
        "apiKey": "vllm-local",
        "baseUrl": "http://vllm:8000/v1",
        "models": [
          {
            "id": "qwen3.6-27b-int4:128k",
            "name": "Qwen3.6 27B INT4 AutoRound + MTP=2",
            "reasoning": true,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 128000,
            "maxTokens": 16384,
            "api": "openai-completions"
          }
        ],
        "api": "openai-completions"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "vllm/qwen3.6-27b-int4:128k"
      },
      "llm": {
        "idleTimeoutSeconds": 1800
      },
      "heartbeat": {
        "every": "1h",
        "target": "none",
        "isolatedSession": true,
        "lightContext": true,
        "activeHours": {
          "start": "08:00",
          "end": "22:00"
        }
      },
      "compaction": {
        "mode": "safeguard"
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Captain Nemo",
        "workspace": "/home/node/.openclaw/workspace",
        "agentDir": "/home/node/.openclaw/agents/main/agent",
        "model": "vllm/qwen3.6-27b-int4:128k",
        "tools": {
          "profile": "messaging",
          "alsoAllow": [
            "prototypes.build",
            "prototypes.list",
            "prototypes.verify",
            "prototypes.store_spec",
            "sessions_spawn"
          ]
        },
        "subagents": {
          "allowAgents": [
            "prototype-builder"
          ],
          "requireAgentId": true
        }
      },
      {
        "id": "prototype-builder",
        "name": "Prototype Builder",
        "workspace": "/home/node/.openclaw/workspaces/prototype-builder",
        "agentDir": "/home/node/.openclaw/agents/prototype-builder/agent",
        "model": "vllm/qwen3.6-27b-int4:128k",
        "sandbox": {
          "mode": "off"
        },
        "tools": {
          "profile": "coding",
          "alsoAllow": [
            "prototypes.allocate",
            "prototypes.archive",
            "prototypes.verify"
          ],
          "deny": [
            "sessions_spawn",
            "browser",
            "canvas"
          ]
        }
      }
    ]
  },
  "meta": {
    "lastTouchedVersion": "2026.4.1",
    "lastTouchedAt": "2026-04-27T00:38:46.022Z"
  },
  "skills": {
    "allowBundled": [
      "weather",
      "healthcheck"
    ]
  },
  "tools": {
    "exec": {
      "security": "full",
      "ask": "off",
      "strictInlineEval": true
    },
    "web": {
      "search": {
        "provider": "brave",
        "maxResults": 5,
        "timeoutSeconds": 30
      }
    }
  },
  "plugins": {
    "slots": {
      "memory": "memory-lancedb"
    },
    "entries": {
      "memory-lancedb": {
        "enabled": false,
        "config": {
          "embedding": {
            "apiKey": "ollama",
            "model": "nomic-embed-text",
            "baseUrl": "http://ollama:11434/v1",
            "dimensions": 768
          },
          "autoCapture": true,
          "autoRecall": true,
          "captureMaxChars": 500
        }
      },
      "brave": {
        "enabled": true
      },
      "prototypes": {
        "enabled": true
      }
    },
    "load": {
      "paths": [
        "/home/node/.openclaw/plugins/openclaw-prototypes"
      ]
    },
    "installs": {
      "prototypes": {
        "source": "path",
        "sourcePath": "/home/node/.openclaw/plugins/openclaw-prototypes",
        "installPath": "/home/node/.openclaw/plugins/openclaw-prototypes",
        "version": "0.1.0",
        "installedAt": "2026-04-27T00:38:45.760Z"
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "streaming": "partial"
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "session-memory-embed": {
          "enabled": true
        }
      }
    }
  }
}
